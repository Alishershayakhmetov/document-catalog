// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url= env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model Users {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mall {
  id String @id @default(cuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalogs Catalog[]
  folders Folder[]
}

model Catalog {
  id String @id @default(cuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mallId      String
  mall        Mall            @relation(fields: [mallId], references: [id], onDelete: Restrict)

  subcatalogs Subcatalog[]
  folders Folder[]
}

model Subcatalog {
  id String @id @default(cuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalogId String
  catalog   Catalog      @relation(fields: [catalogId], references: [id], onDelete: Restrict)

  documentations Documentation[]
  folders Folder[]
}

model Documentation {
  id String @id @default(cuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcatalogId String
  subcatalog   Subcatalog  @relation(fields: [subcatalogId], references: [id], onDelete: Restrict)

  folders Folder[]
}

model Folder {
  id String @id @default(cuid())
  name String
  date DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mallId String?
  documentationId String?
  catalogId String?
  subcatalogId String?

  mall Mall? @relation(fields: [mallId], references: [id], onDelete: Restrict)
  documentation   Documentation? @relation(fields: [documentationId], references: [id], onDelete: Restrict)
  catalog   Catalog? @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  subcatalog   Subcatalog? @relation(fields: [subcatalogId], references: [id], onDelete: Restrict)

  files        File[]
}

model File {
  id               String   @id @default(cuid())
  originalFilename String
  storedFilename   String   @unique
  mimeType         String?
  fileSize         Int
  uploadedAt       DateTime @default(now())
  updatedAt DateTime @updatedAt
  folderId     String
  folderIdRelation       Folder     @relation(fields: [folderId], references: [id])
  date DateTime @default(now())
  systemName String
  physicalLocation String?
}